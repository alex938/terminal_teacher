# Django Secret Key (REQUIRED - generate a new one for production)
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production

# Admin Password (REQUIRED)
ADMIN_PASSWORD=your-admin-password-here

# Allowed Hosts (comma-separated, required unless ALLOW_ALL_HOSTS=true)
ALLOWED_HOSTS=localhost,127.0.0.1

# Allow all hosts (useful for teacher LAN access, but less secure)
# Set to 'true' to allow any IP to access the server
ALLOW_ALL_HOSTS=false

# Debug Mode (should be False in production)
DEBUG=False

# Database Path (optional, defaults to data/db.sqlite3)
DATABASE_PATH=/app/data/db.sqlite3
